# Patterns to exclude when packaging the chart.
.git/
.gitignore
.DS_Store
# Ignore only stray root-level archives — subchart archives under charts/ (e.g. the
# bundled openclaw-operator dependency) MUST be packaged into the chart.
/*.tgz
*.bak
*.orig
# Dev-only / reference assets (not part of the released chart):
ci/
tests/
*_test.yaml
crd-schema/
