{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "openclaw-instance values",
  "type": "object",
  "properties": {
    "instance": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "labels": { "type": "object" },
        "annotations": { "type": "object" }
      }
    },
    "operator": {
      "type": "object",
      "properties": {
        "install": { "type": "boolean" },
        "required": { "type": "boolean" }
      }
    },
    "openclaw-operator": { "type": "object" },
    "registry": { "type": "string" },
    "image": {
      "type": "object",
      "required": ["repository"],
      "properties": {
        "repository": { "type": "string", "minLength": 1 },
        "tag": { "type": "string" },
        "digest": { "type": "string" },
        "pullPolicy": { "type": "string", "enum": ["Always", "IfNotPresent", "Never"] },
        "pullSecrets": { "type": "array" }
      }
    },
    "config": {
      "type": "object",
      "properties": {
        "raw": { "type": "object" },
        "configMapRef": { "type": "string" },
        "fromFiles": { "type": "object" },
        "mergeMode": { "type": "string" },
        "format": { "type": "string" }
      }
    },
    "skills": { "type": "array" },
    "plugins": { "type": "array" },
    "env": { "type": "array" },
    "envFrom": { "type": "array" },
    "secrets": {
      "type": "object",
      "properties": {
        "create": { "type": "boolean" },
        "existingSecret": { "type": "string" },
        "data": { "type": "object" }
      }
    },
    "resources": { "type": "object" },
    "persistence": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "storageClass": { "type": "string" },
        "size": { "type": "string", "pattern": "^[0-9]+(\\.[0-9]+)?(Ei|Pi|Ti|Gi|Mi|Ki|E|P|T|G|M|k|m)?$" },
        "accessModes": {
          "type": "array",
          "items": { "type": "string", "enum": ["ReadWriteOnce", "ReadWriteOncePod", "ReadWriteMany"] }
        },
        "existingClaim": { "type": "string" },
        "orphan": { "type": "boolean" }
      }
    },
    "security": {
      "type": "object",
      "properties": {
        "podSecurityContext": { "type": "object" },
        "containerSecurityContext": { "type": "object" },
        "networkPolicy": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "allowDNS": { "type": "boolean" },
            "allowedIngressNamespaces": { "type": "array" },
            "allowedIngressCIDRs": { "type": "array" }
          }
        },
        "rbac": {
          "type": "object",
          "properties": {
            "createServiceAccount": { "type": "boolean" }
          }
        },
        "caBundle": { "type": "string" }
      }
    },
    "chromium": {
      "type": "object",
      "properties": { "enabled": { "type": "boolean" } }
    },
    "tailscale": {
      "type": "object",
      "properties": { "enabled": { "type": "boolean" } }
    },
    "ollama": { "type": "object" },
    "webTerminal": {
      "type": "object",
      "properties": { "enabled": { "type": "boolean" } }
    },
    "networking": {
      "type": "object",
      "properties": {
        "service": {
          "type": "object",
          "properties": {
            "type": { "type": "string", "enum": ["ClusterIP", "NodePort", "LoadBalancer"] },
            "annotations": { "type": "object" }
          }
        },
        "ingress": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "className": { "type": "string" },
            "annotations": { "type": "object" },
            "hosts": { "type": "array" },
            "tls": { "type": "array" },
            "security": { "type": "object" }
          }
        }
      }
    },
    "probes": { "type": "object" },
    "observability": {
      "type": "object",
      "properties": {
        "metrics": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
            "serviceMonitor": { "type": "object" }
          }
        },
        "logging": {
          "type": "object",
          "properties": {
            "level": { "type": "string" },
            "format": { "type": "string" }
          }
        }
      }
    },
    "availability": {
      "type": "object",
      "properties": {
        "podDisruptionBudget": { "type": "object" },
        "autoScaling": { "type": "object" },
        "nodeSelector": { "type": "object" },
        "tolerations": { "type": "array" },
        "affinity": { "type": "object" },
        "topologySpreadConstraints": { "type": "array" },
        "runtimeClassName": { "type": "string" }
      }
    },
    "suspended": { "type": "boolean" },
    "restoreFrom": { "type": "string" },
    "autoUpdate": {
      "type": "object",
      "properties": { "enabled": { "type": "boolean" } }
    },
    "selfConfigure": {
      "type": "object",
      "properties": { "enabled": { "type": "boolean" } }
    },
    "podAnnotations": { "type": "object" },
    "extraNetworkPolicy": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "podSelector": { "type": "object" },
        "policyTypes": { "type": "array" },
        "ingress": { "type": "array" },
        "egress": { "type": "array" }
      }
    },
    "extraSpec": { "type": "object" },
    "nameOverride": { "type": "string" },
    "fullnameOverride": { "type": "string" }
  }
}
